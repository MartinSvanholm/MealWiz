@inherits LayoutComponentBase

<MudThemeProvider Theme="MealWizTheme" IsDarkMode />
<MudPopoverProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Bottom Gutters="false" Elevation="20" Fixed Color="@Color.Transparent">
        <NavMenu />
    </MudAppBar>
    <DrawerBase />
    <MudMainContent Class="pa-0">
        @Body
    </MudMainContent>
    
</MudLayout>


@code {
    MudTheme MealWizTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#D9944F"
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#D9944F",
            TextPrimary = "#e4e4e7"
        }
    };
}