@inject IDrawerStateContainer _drawerStateContainer

<MudDrawer Width="100%" Height="@_drawerStateContainer.StateParameters.Height" Elevation="4" @bind-Open="_drawerStateContainer.IsDrawerOpen" Anchor="Anchor.Bottom" Variant="DrawerVariant.Temporary">
    <MudDrawerHeader Class="pl-2" Style="@($"background: var(--mud-palette-primary); color: white;")">
        @if (_drawerStateContainer.StateParameters.Header != null)
        {
            @_drawerStateContainer.StateParameters.Header
        }
        else
        {
            <MudStack Style="width: 100%;" Row=true Justify="Justify.FlexStart" AlignItems="AlignItems.Center">
                @if (_drawerStateContainer.DrawerNavigationStack.Count > 1)
                {
                    <MudIconButton OnClick="_drawerStateContainer.NavigateBack" Class="white-text" Icon="@Icons.Material.Filled.ArrowBack" />
                }
                else
                {
                    <MudIconButton OnClick="_drawerStateContainer.CloseDrawer" Class="white-text" Icon="@Icons.Material.Filled.Close" />
                }
                <MudText Typo="Typo.h6">@_drawerStateContainer.StateParameters.Title</MudText>
            </MudStack>
        }
    </MudDrawerHeader>
    <div style="flex: 1 1 0; min-height: 0; overflow: hidden; display: flex; flex-direction: column;">
        @if (_drawerStateContainer.StateParameters.Content != null)
        {
            <DynamicComponent Type="_drawerStateContainer.StateParameters.Content" Parameters="_drawerStateContainer.StateParameters.ContentParameters" />
        }
    </div>
</MudDrawer>

@code {
    protected override void OnInitialized()
    {
        _drawerStateContainer.OnDrawerChange += StateHasChanged;
    }
}