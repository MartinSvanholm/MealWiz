@using System.Text.RegularExpressions
@using System.Web
@inject IMealPlanStateContainer _mealPlanStateContainer
@implements IDisposable

<MudStack Class="pa-5">
    <div class="d-flex justify-center">
        <MudText Typo="Typo.h5">@Meal.Name</MudText>
    </div>

    <MudText Typo="Typo.h6">Ingredients</MudText>
    <MudDivider />
    <MudStack Spacing="0">
        @foreach (var ingredient in Meal.Ingredients)
        {
            <MudText>@ingredient.Amount @ingredient.Name.ToLower()</MudText>
        }
    </MudStack>

    <MudText Typo="Typo.h6">Recipe</MudText>
    <MudDivider />

    <MudStack Spacing="2">
        @foreach (var step in GetRecipeSteps())
        {
            <MudText>@step</MudText>
        }
    </MudStack>
</MudStack>

@code {
    protected override void OnInitialized()
    {
        _mealPlanStateContainer.OnStateChanged += StateHasChanged;

        base.OnInitialized();
    }

    public void Dispose()
    {
        _mealPlanStateContainer.OnStateChanged -= StateHasChanged;
    }

    public Meal Meal => _mealPlanStateContainer.GetMealFromSelectedDate();

    private List<string> GetRecipeSteps() {
        return Meal.Recipe.Split(new[] { "\r\n", "\r", "\n" }, StringSplitOptions.RemoveEmptyEntries).ToList();
    }
}