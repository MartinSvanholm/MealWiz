@using System.Text.RegularExpressions
@using System.Web
@inject IMealPlanStateContainer _mealPlanStateContainer
@inject IMediator _mediator
@inject ISnackbar _snackbar
@implements IDisposable

<MudStack Class="pa-5"> 
    @if (Meal == null) 
    {
        <AddMealDropdown />
    }
    else 
    {
        <div class="d-flex justify-center">
            <MudText Typo="Typo.h5">@Meal.Name</MudText>
        </div>

        <MudText Typo="Typo.h6">Ingredients</MudText>
        <MudDivider />
        <MudStack Spacing="0">
            @foreach (var ingredient in Meal.Ingredients)
            {
                <MudText>@ingredient.Amount @ingredient.Name.ToLower()</MudText>
            }
        </MudStack>

        <MudText Typo="Typo.h6">Recipe</MudText>
        <MudDivider />

        <MudStack Spacing="2">
            @foreach (var step in GetRecipeSteps())
            {
                <MudText>@step</MudText>
            }
        </MudStack>
    }
</MudStack>

@code {
    public Meal? Meal { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Meal = _mealPlanStateContainer.GetMealFromSelectedDate();
        _mealPlanStateContainer.OnStateChanged += StateChanged;

        base.OnInitialized();
    }

    public void Dispose()
    {
        _mealPlanStateContainer.OnStateChanged -= StateChanged;
    }

    private List<string> GetRecipeSteps() 
    {
        if (Meal == null) return [];

        return Meal.Recipe.Split(new[] { "\r\n", "\r", "\n" }, StringSplitOptions.RemoveEmptyEntries).ToList();
    }

    private void StateChanged()
    {
        Meal = _mealPlanStateContainer.GetMealFromSelectedDate();

        StateHasChanged();
    }
}