@attribute [Authorize]
@page "/meals"
@inject IMealsStateContainer _mealsStateContainer
@inject ISnackbar _snackbar
@inject Client _client;
@inject NavigationManager _navigationManager

<MudStack Spacing="0" Style="height: calc(100vh - 56px)">
    <MudPaper>
        <MudGrid Spacing="0" Class="my-1">
            <MudItem xs="4" Class="d-flex align-center flex-row justify-start pl-1">
                <MudIconButton OnClick="OnAccountClicked" Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Primary" />
            </MudItem>
            <MudItem xs="4" Class="d-flex align-center flex-row justify-center">
                <MudText Typo="Typo.h6">Your meals</MudText>
            </MudItem>
            <MudItem xs="4" Class="d-flex align-center flex-row justify-end pr-1">
                <MudIconButton OnClick="OnAddClick" Icon="@Icons.Material.Filled.Add" Color="Color.Secondary" />
            </MudItem>
        </MudGrid>
    </MudPaper>

    <div style="height: calc(100vh - 56px - 48px)" class="overflow-y-auto">
        <MudStack Class="px-3 pt-3">
            @foreach (Meal meal in _mealsStateContainer.Meals)
            {
                <MealCard Meal="meal" />
            }
        </MudStack>
    </div>


</MudStack>


@code {
    protected override async Task OnInitializedAsync()
    {
        _mealsStateContainer.CurrentSnackbar = _snackbar;
        _mealsStateContainer.OnStateChanged += StateHasChanged;

        await _mealsStateContainer.LoadMeals();

        await base.OnInitializedAsync();
    }

    private void OnAccountClicked()
    {
        _navigationManager.NavigateTo("/account");
    }

    private void OnAddClick()
    {
        _mealsStateContainer.MealToEdit = new();
        _navigationManager.NavigateTo("/meals/edit");
    }
}