@inject IMealsStateContainer _mealsStateContainer
@inject IDrawerStateContainer _drawerStateContainer
@implements IDisposable

<BaseCard CardColor="Color.Primary">
    <HeaderContent>
        <MudText Typo="Typo.h6">@Meal.Name</MudText>
        <MudLoadingButton OnClick="OnDeleteClick" ButtonVariant="@ButtonVariant.IconButton" Icon="@Icons.Material.Filled.Delete" Size="Size.Medium" Class="pa-1" />
    </HeaderContent>
</BaseCard>

@code {
    public void Dispose()
    {
        _drawerStateContainer.OnConfirmClick -= OnConfirmDelete;
    }

    [Parameter]
    public Meal Meal { get; set; }

    private async Task OnDeleteClick()
    {
        _drawerStateContainer.OnConfirmClick += OnConfirmDelete;
        _drawerStateContainer.OpenConfirmDrawer("Delete Meal?", "Are you sure you want to delete this meal?");
    }

    private async Task OnConfirmDelete()
    {
        await _mealsStateContainer.DeleteMeal(Meal);

        _drawerStateContainer.OnConfirmClick -= OnConfirmDelete;
    }
}
