@inject IMealsStateContainer _mealsStateContainer
@inject IDrawerStateContainer _drawerStateContainer

<BaseCard CardColor="Color.Primary">
    <HeaderContent>
        <MudText Typo="Typo.h6">@Meal.Name</MudText>
        <MudLoadingButton OnClick="OnDeleteClick" @bind-Loading="DeleteBtnLoading" ButtonVariant="@ButtonVariant.IconButton" Icon="@Icons.Material.Filled.Delete" Size="Size.Medium" Class="pa-1" />
    </HeaderContent>
</BaseCard>

@code {
    [Parameter]
    public Meal Meal { get; set; }

    private bool DeleteBtnLoading { get; set; }

    private async Task OnDeleteClick()
    {
        DeleteBtnLoading = true;

        _drawerStateContainer.OpenDrawer("Are you sure", typeof(ConfirmDrawer));

        DeleteBtnLoading = false;
    }
}
