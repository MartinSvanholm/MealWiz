@inject IMediator _mediator
@inject ISnackbar _snackbar
@inject IMealPlanStateContainer _mealPlanStateContainer

<MudButton Class="ma-3" Variant="Variant.Filled" Color="Color.Secondary" OnClick="CreateMealPlan">
    Create meal plan for Week @System.Globalization.ISOWeek.GetWeekOfYear(_mealPlanStateContainer.SelectedWeekStart)
</MudButton>

@code {
    private async Task CreateMealPlan()
    {
        var mealPlan = new MealPlan(_mealPlanStateContainer.SelectedWeekStart);

        var result = await _mediator.Send(new CreateMealPlan.Command(mealPlan));

        if (result.Handle(_snackbar).IsFailed) return;

        _mealPlanStateContainer.MealPlan = result.Value;
    }
}
