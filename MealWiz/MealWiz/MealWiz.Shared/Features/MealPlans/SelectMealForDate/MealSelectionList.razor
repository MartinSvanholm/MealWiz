@inject IMealPlanStateContainer _mealPlanStateContainer
@inject IMealsStateContainer _mealsStateContainer
@inject ISnackbar _snackbar
@inject NavigationManager _navigationManager
@implements IDisposable

<MudStack Class="pa-5" Spacing="3">
    <MudText Typo="Typo.h6">
        Pick a meal for @_mealPlanStateContainer.SelectedDate.DayOfWeek.ToString().ToLower()
    </MudText>

    <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
        <MudTextField T="string"
                      @bind-Value="_search"
                      Placeholder="Search meals"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true"
                      Clearable="true" />
        <MudIconButton Icon="@Icons.Material.Filled.Shuffle"
                       Color="Color.Tertiary"
                       Variant="Variant.Filled"
                       OnClick="ShuffleAsync"
                       Disabled="_isShuffling" />
    </MudStack>

    @if (_mealsStateContainer.Meals.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mt-3">
            You have no meals yet. Create one from the Meals page.
        </MudText>
    }
    else
    {
        <MudStack Spacing="2">
            @foreach (var meal in FilteredMeals)
            {
                <MudPaper Class="d-flex align-center justify-space-between pa-3 rounded-lg cursor-pointer"
                          Elevation="2"
                          @onclick="() => AssignMeal(meal)">
                    <MudText Typo="Typo.body1">@meal.Name</MudText>
                    <span @onclick:stopPropagation="true" @onclick="() => EditMeal(meal)">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Primary"
                                       Size="Size.Small" />
                    </span>
                </MudPaper>
            }
        </MudStack>
    }
</MudStack>

@code {
    private string _search = string.Empty;
    private List<Meal> _shuffled = [];
    private bool _isShuffling;

    protected override async Task OnInitializedAsync()
    {
        _mealsStateContainer.CurrentSnackbar = _snackbar;
        _mealsStateContainer.OnStateChanged += StateHasChanged;
        _mealPlanStateContainer.OnStateChanged += StateHasChanged;

        await _mealsStateContainer.LoadMeals();
        Shuffle();
    }

    public void Dispose()
    {
        _mealsStateContainer.OnStateChanged -= StateHasChanged;
        _mealPlanStateContainer.OnStateChanged -= StateHasChanged;
    }

    private IEnumerable<Meal> FilteredMeals =>
        string.IsNullOrWhiteSpace(_search)
            ? _shuffled
            : _shuffled.Where(m => m.Name.Contains(_search, StringComparison.InvariantCultureIgnoreCase));

    private void Shuffle()
    {
        var list = _mealsStateContainer.Meals.ToList();
        for (int i = list.Count - 1; i > 0; i--)
        {
            int j = Random.Shared.Next(i + 1);
            (list[i], list[j]) = (list[j], list[i]);
        }
        _shuffled = list;
    }

    private async Task ShuffleAsync()
    {
        _isShuffling = true;
        await _mealsStateContainer.LoadMeals();
        Shuffle();
        _isShuffling = false;
    }

    private async Task AssignMeal(Meal meal)
    {
        _mealPlanStateContainer.CurrentSnackbar = _snackbar;
        await _mealPlanStateContainer.AddMealToPlan(meal);
    }

    private void EditMeal(Meal meal)
    {
        _mealsStateContainer.MealToEdit = meal;
        _navigationManager.NavigateTo("/meals/edit");
    }
}
