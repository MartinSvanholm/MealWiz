@page "/"
@attribute [Authorize]
@implements IDisposable
@inject IMealPlanStateContainer _mealPlanStateContainer
@inject ISnackbar _snackbar

<MudStack Spacing="0" Style="height: calc(100vh - 56px)">
    <MudPaper>
        <MudGrid Spacing="0" Class="my-2">
            <MudItem xs="4" Class="d-flex align-center flex-row justify-start pl-2">
                <MudIconButton Icon="@Icons.Material.Filled.AccountCircle" />
            </MudItem>
            <MudItem xs="4" Class="d-flex align-center flex-row justify-center">
                <MudText Typo="Typo.h6">Meal plan</MudText>
            </MudItem>
            <MudItem xs="4" Class="d-flex align-center flex-row justify-end pr-2">
                @if (_mealPlanStateContainer.SelectedDateHasMeal) 
                {
                    <RemoveMealButton />
                }
                <MudIconButton Icon="@Icons.Material.Filled.EditCalendar" />
            </MudItem>
        </MudGrid>

        @if (_mealPlanStateContainer.MealPlan != null) {
            <MudDivider Class="mb-4" DividerType="DividerType.Middle" />
            <MudStack Class="mb-3">
                <MealPlanWeekOverview />
            </MudStack>
        }
    </MudPaper>

    <div style="height: calc(100vh - 56px - 48px)" class="overflow-y-auto">
        @if (IsLoading) 
        {
            <MudProgressLinear Indeterminate Color="@Color.Primary" />
        }  
        else if (_mealPlanStateContainer.MealPlan == null)
        {
            <CreateMealPlanButton />
        }
        else if (_mealPlanStateContainer.MealPlan.Id > 0)
        {
            <MealDisplayComponent />
        }
    </div>

</MudStack>

@code {
    private bool IsLoading { get; set; }

    protected override async Task OnInitializedAsync()
    {
        IsLoading = true;

        _mealPlanStateContainer.CurrentSnackbar = _snackbar;
        _mealPlanStateContainer.OnStateChanged += StateHasChanged;

        await _mealPlanStateContainer.LoadMealPlan();

        IsLoading = false;

        await base.OnInitializedAsync();
    }

    public void Dispose()
    {
        _mealPlanStateContainer.OnStateChanged -= StateHasChanged;
    }
}