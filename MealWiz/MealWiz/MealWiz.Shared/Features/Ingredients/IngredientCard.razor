@inject IDrawerStateContainer _drawerStateContainer
@inject IIngredientStateContainer _ingredientStateContainer
@inject IMealsStateContainer _mealsStateContainer
@inject IMediator _mediator
@inject ISnackbar _snackbar

<BaseCard Dense CardColor="Color.Primary" OnClick="() => _ingredientStateContainer.EditIngredient(Ingredient)">
    <HeaderContent>
        <MudText  Typo="Typo.h6">@Ingredient.Name</MudText>
        <MudLoadingButton OnClick="OnDeleteClick" ButtonVariant="@ButtonVariant.IconButton" Icon="@Icons.Material.Filled.Delete" Size="Size.Medium" Class="pa-1" />
    </HeaderContent>
    <Content>
        <div class="d-flex mt-2">
            <MudIcon Size="Size.Small" Icon="@Icons.Material.Filled.Scale" />
            <MudText Class="mx-2">@Ingredient.Amount</MudText>
        </div>
    </Content>
</BaseCard>

@code {
    [Parameter]
    public Ingredient Ingredient { get; set; }

    private void OnDeleteClick()
    {
        _drawerStateContainer.OnConfirmClick += OnConfirmDelete;
        _drawerStateContainer.OpenConfirmDrawer("Delete ingredient?", "Are you sure you want to delete this ingredient?");
    }

    private async Task OnConfirmDelete()
    {
        var result = await _mediator.Send(new DeleteIngredient.DeleteIngredient.Command(Ingredient));

        result.Handle(_snackbar);

        if (result.IsSuccess)
        {
            _mealsStateContainer.MealToEdit.Ingredients.Remove(Ingredient);
            _snackbar.Add("Ingredient deleted.", Severity.Success);
        }

        _mealsStateContainer.NotifyStateChanged();
        _drawerStateContainer.OnConfirmClick -= OnConfirmDelete;
    }
}
