@attribute [Authorize]
@page "/account"
@using MealWiz.Shared.Theme
@inject IThemeService ThemeService
@inject NavigationManager _navigationManager

<MudStack Spacing="0" Style="height: calc(100vh - 56px)">
    <MudPaper>
        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="my-1 px-1">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => _navigationManager.NavigateTo("/"))" />
            <MudText Typo="Typo.h6">Account</MudText>
            <LogoutButton />
        </MudStack>
    </MudPaper>

    <div style="height: calc(100vh - 56px - 48px)" class="overflow-y-auto">
        <MudStack Class="pa-4" Spacing="3">
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Settings</MudText>
            <MudPaper Class="pa-3" Elevation="0" Outlined>
                <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@(ThemeService.IsDarkMode ? Icons.Material.Outlined.DarkMode : Icons.Material.Outlined.LightMode)" />
                        <MudText>Dark mode</MudText>
                    </MudStack>
                    <MudSwitch T="bool"
                               Value="ThemeService.IsDarkMode"
                               ValueChanged="OnToggleDarkMode"
                               Color="Color.Primary" />
                </MudStack>
            </MudPaper>
        </MudStack>
    </div>
</MudStack>

@code {
    private async Task OnToggleDarkMode(bool _) => await ThemeService.ToggleAsync();
}
